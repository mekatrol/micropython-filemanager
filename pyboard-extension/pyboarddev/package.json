{
  "name": "mekatrol-pydevice",
  "publisher": "Mekatrol",
  "displayName": "Mekatrol Pydevice",
  "description": "A Python device developer extension.",
  "icon": "images/logo.png",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onFileSystem:pydevice-device"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mekatrol.pydevice.initconfig",
        "title": "Pydevice: Reset config"
      },
      {
        "command": "mekatrol.pydevice.selectdevice",
        "title": "Pydevice: Select serial port"
      },
      {
        "command": "mekatrol.pydevice.autodetectdevices",
        "title": "Pydevice: Auto detect serial devices",
        "icon": "$(search)"
      },
      {
        "command": "mekatrol.pydevice.connectboard",
        "title": "Pydevice: Connect to board",
        "icon": "$(plug)"
      },
      {
        "command": "mekatrol.pydevice.connectboardwithpicker",
        "title": "Pydevice: Connect to board (choose port)",
        "icon": "$(plug)"
      },
      {
        "command": "mekatrol.pydevice.connectboardesp32recovery",
        "title": "Pydevice: ESP32 Recovery Connect",
        "icon": "$(debug-restart)"
      },
      {
        "command": "mekatrol.pydevice.disconnectboard",
        "title": "Pydevice: Disconnect from board"
      },
      {
        "command": "mekatrol.pydevice.toggleboardconnection",
        "title": "Pydevice: Toggle board connection"
      },
      {
        "command": "mekatrol.pydevice.softreboot",
        "title": "Pydevice: Soft reboot device",
        "icon": "$(debug-restart)"
      },
      {
        "command": "mekatrol.pydevice.setautoreconnect",
        "title": "Pydevice: Set auto reconnect"
      },
      {
        "command": "mekatrol.pydevice.refreshsyncview",
        "title": "Pydevice: Refresh sync explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "mekatrol.pydevice.explorerprerequisiteshint",
        "title": "Pydevice: Explorer setup required",
        "icon": "$(info)"
      },
      {
        "command": "mekatrol.pydevice.explorerinitialiseworkspace",
        "title": "Pydevice: Initialize explorer workspace",
        "icon": "$(tools)"
      },
      {
        "command": "mekatrol.pydevice.syncfromdevice",
        "title": "Pydevice: Sync from device to computer",
        "icon": "$(cloud-download)"
      },
      {
        "command": "mekatrol.pydevice.synctodevice",
        "title": "Pydevice: Sync from computer to device",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "mekatrol.pydevice.syncnodefromdevice",
        "title": "Sync from device to computer",
        "icon": "$(cloud-download)"
      },
      {
        "command": "mekatrol.pydevice.syncnodetodevice",
        "title": "Sync from computer to device",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "mekatrol.pydevice.opencomputersyncitem",
        "title": "Open Computer Sync Item"
      },
      {
        "command": "mekatrol.pydevice.pullandopendeviceitem",
        "title": "Pull and Open Device Item"
      },
      {
        "command": "mekatrol.pydevice.opendevicefile",
        "title": "Open Device File"
      },
      {
        "command": "mekatrol.pydevice.comparedevicewithcomputer",
        "title": "Compare Device File With Computer",
        "enablement": "viewItem != pydevice.deviceFileUnlinked && viewItem != pydevice.deviceFileExcludedUnlinked && viewItem != pydevice.deviceFileHostMissing && viewItem != pydevice.deviceFileExcludedHostMissing",
        "icon": "$(diff)"
      },
      {
        "command": "mekatrol.pydevice.openrepl",
        "title": "Pydevice: Open REPL console"
      },
      {
        "command": "mekatrol.pydevice.clearrepl",
        "title": "Pydevice: Clear REPL console",
        "icon": {
          "light": "images/clear-all-light.svg",
          "dark": "images/clear-all-dark.svg"
        }
      },
      {
        "command": "mekatrol.pydevice.clearreplhistory",
        "title": "Pydevice: Clear REPL command history",
        "icon": {
          "light": "images/clear-history-light.svg",
          "dark": "images/clear-history-dark.svg"
        }
      },
      {
        "command": "mekatrol.pydevice.createsyncfile",
        "title": "Create File",
        "icon": "$(new-file)"
      },
      {
        "command": "mekatrol.pydevice.createsyncfolder",
        "title": "Create Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "mekatrol.pydevice.renamesyncpath",
        "title": "Rename"
      },
      {
        "command": "mekatrol.pydevice.deletesyncpath",
        "title": "Delete"
      },
      {
        "command": "mekatrol.pydevice.linkdevicehostfolder",
        "title": "Pydevice: Link device to computer folder"
      },
      {
        "command": "mekatrol.pydevice.unlinkdevicehostfolder",
        "title": "Pydevice: Unlink device from computer folder"
      },
      {
        "command": "mekatrol.pydevice.adddevicelibraryfolder",
        "title": "Pydevice: Add device library folder"
      },
      {
        "command": "mekatrol.pydevice.removedevicelibraryfolder",
        "title": "Pydevice: Remove device library folder"
      },
      {
        "command": "mekatrol.pydevice.setdevicename",
        "title": "Pydevice: Set device name"
      },
      {
        "command": "mekatrol.pydevice.excludedevicefilefromsync",
        "title": "Exclude From Sync"
      },
      {
        "command": "mekatrol.pydevice.removedevicefilefromsyncexclusion",
        "title": "Remove Sync Exclusion"
      },
      {
        "command": "mekatrol.pydevice.closedeviceconnection",
        "title": "Close Connection",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "mekatrol.pydevice.closealldeviceconnections",
        "title": "Close All Connections",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "mekatrol.pydevice.syncExplorer.focus",
        "title": "Focus on Pydevice Explorer View"
      },
      {
        "command": "mekatrol.pydevice.statusView.focus",
        "title": "Focus on Pydevice View"
      },
      {
        "command": "mekatrol.pydevice.replView.focus",
        "title": "Focus on Pydevice REPL View"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mekatrol-pydevice-sidebar",
          "title": "Pydevice",
          "icon": "images/pydevice-sidebar.svg"
        }
      ],
      "panel": [
        {
          "id": "mekatrol-pydevice-panel",
          "title": "Pydevice REPL",
          "icon": "images/pydevice-sidebar.svg"
        }
      ]
    },
    "views": {
      "mekatrol-pydevice-sidebar": [
        {
          "id": "mekatrol.pydevice.syncExplorer",
          "name": "Pydevice Explorer"
        },
        {
          "id": "mekatrol.pydevice.statusView",
          "name": "PYDEVICE",
          "when": "mekatrol.pydevice.showExtensionStatusView"
        }
      ],
      "mekatrol-pydevice-panel": [
        {
          "id": "mekatrol.pydevice.replView",
          "name": "REPL",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "mekatrol.pydevice.initconfig",
          "when": "true"
        },
        {
          "command": "mekatrol.pydevice.selectdevice",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.autodetectdevices",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.connectboard",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.connectboardwithpicker",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.connectboardesp32recovery",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.disconnectboard",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.toggleboardconnection",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.softreboot",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.setautoreconnect",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.refreshsyncview",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.syncfromdevice",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.synctodevice",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.syncnodefromdevice",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.syncnodetodevice",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.opencomputersyncitem",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.pullandopendeviceitem",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.opendevicefile",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.comparedevicewithcomputer",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.openrepl",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.clearrepl",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.clearreplhistory",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.createsyncfile",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.createsyncfolder",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.renamesyncpath",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.deletesyncpath",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.linkdevicehostfolder",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.unlinkdevicehostfolder",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.setdevicename",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.adddevicelibraryfolder",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.removedevicelibraryfolder",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.excludedevicefilefromsync",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.removedevicefilefromsyncexclusion",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.closedeviceconnection",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.closealldeviceconnections",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.syncExplorer.focus",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.statusView.focus",
          "when": "false"
        },
        {
          "command": "mekatrol.pydevice.replView.focus",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "mekatrol.pydevice.explorerinitialiseworkspace",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerHasWorkspace && !mekatrol.pydevice.explorerReady",
          "group": "navigation@0"
        },
        {
          "command": "mekatrol.pydevice.explorerprerequisiteshint",
          "when": "view == mekatrol.pydevice.syncExplorer && !mekatrol.pydevice.explorerHasWorkspace",
          "group": "navigation@0"
        },
        {
          "command": "mekatrol.pydevice.refreshsyncview",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady",
          "group": "navigation@1"
        },
        {
          "command": "mekatrol.pydevice.syncfromdevice",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady",
          "group": "navigation@2"
        },
        {
          "command": "mekatrol.pydevice.synctodevice",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady",
          "group": "navigation@3"
        },
        {
          "command": "mekatrol.pydevice.clearrepl",
          "when": "view == mekatrol.pydevice.replView",
          "group": "navigation@1"
        },
        {
          "command": "mekatrol.pydevice.clearreplhistory",
          "when": "view == mekatrol.pydevice.replView",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "mekatrol.pydevice.opencomputersyncitem",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && (viewItem == pydevice.hostFile || viewItem == pydevice.hostFileExcluded)",
          "group": "navigation@1"
        },
        {
          "command": "mekatrol.pydevice.connectboardwithpicker",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && viewItem == pydevice.deviceRoot",
          "group": "inline@1"
        },
        {
          "command": "mekatrol.pydevice.connectboardesp32recovery",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && viewItem == pydevice.deviceRoot",
          "group": "inline@1.5"
        },
        {
          "command": "mekatrol.pydevice.closealldeviceconnections",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && viewItem == pydevice.deviceRoot && mekatrol.pydevice.boardConnected",
          "group": "inline@2"
        },
        {
          "command": "mekatrol.pydevice.autodetectdevices",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && viewItem == pydevice.deviceRoot",
          "group": "inline@3"
        },
        {
          "command": "mekatrol.pydevice.opendevicefile",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && (viewItem == pydevice.deviceFileLinked || viewItem == pydevice.deviceFileHostMissing || viewItem == pydevice.deviceFileUnlinked || viewItem == pydevice.deviceFileExcludedLinked || viewItem == pydevice.deviceFileExcludedHostMissing || viewItem == pydevice.deviceFileExcludedUnlinked)",
          "group": "navigation@2"
        },
        {
          "command": "mekatrol.pydevice.comparedevicewithcomputer",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && (viewItem == pydevice.hostFile || viewItem == pydevice.hostFileExcluded || viewItem == pydevice.deviceFileLinked || viewItem == pydevice.deviceFileExcludedLinked || viewItem == pydevice.deviceFileHostMissing || viewItem == pydevice.deviceFileExcludedHostMissing)",
          "group": "navigation@3"
        },
        {
          "command": "mekatrol.pydevice.syncnodefromdevice",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && (viewItem == pydevice.deviceFileLinked || viewItem == pydevice.deviceFileHostMissing || viewItem == pydevice.deviceFileUnlinked || viewItem == pydevice.deviceFolder || viewItem == pydevice.deviceIdNode || viewItem == pydevice.deviceIdNodeLinked || viewItem == pydevice.deviceLibraryNode || viewItem == pydevice.deviceLibraryNodeMissing)",
          "group": "navigation@4"
        },
        {
          "command": "mekatrol.pydevice.syncnodetodevice",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && (viewItem == pydevice.deviceFileLinked || viewItem == pydevice.deviceFileHostMissing || viewItem == pydevice.deviceFileUnlinked || viewItem == pydevice.deviceFolder || viewItem == pydevice.deviceIdNode || viewItem == pydevice.deviceIdNodeLinked || viewItem == pydevice.deviceLibraryNode || viewItem == pydevice.deviceLibraryNodeMissing)",
          "group": "navigation@5"
        },
        {
          "command": "mekatrol.pydevice.excludedevicefilefromsync",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && (viewItem == pydevice.deviceFileLinked || viewItem == pydevice.deviceFileHostMissing || viewItem == pydevice.deviceFileUnlinked || viewItem == pydevice.deviceFolder)",
          "group": "navigation@5.1"
        },
        {
          "command": "mekatrol.pydevice.removedevicefilefromsyncexclusion",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && (viewItem == pydevice.deviceFileExcludedLinked || viewItem == pydevice.deviceFileExcludedHostMissing || viewItem == pydevice.deviceFileExcludedUnlinked || viewItem == pydevice.deviceFolderExcluded)",
          "group": "navigation@5.2"
        },
        {
          "command": "mekatrol.pydevice.createsyncfile",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && (viewItem == pydevice.hostRoot || viewItem == pydevice.hostFolder || viewItem == pydevice.deviceFolder || viewItem == pydevice.deviceIdNode || viewItem == pydevice.deviceIdNodeLinked || viewItem == pydevice.hostDeviceMappingNode || viewItem == pydevice.deviceLibraryNode || viewItem == pydevice.deviceLibraryNodeMissing)",
          "group": "navigation@6"
        },
        {
          "command": "mekatrol.pydevice.createsyncfolder",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && (viewItem == pydevice.hostRoot || viewItem == pydevice.hostFolder || viewItem == pydevice.deviceFolder || viewItem == pydevice.deviceIdNode || viewItem == pydevice.deviceIdNodeLinked || viewItem == pydevice.hostDeviceMappingNode || viewItem == pydevice.deviceLibraryNode || viewItem == pydevice.deviceLibraryNodeMissing)",
          "group": "navigation@7"
        },
        {
          "command": "mekatrol.pydevice.renamesyncpath",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && (viewItem == pydevice.hostFile || viewItem == pydevice.hostFileExcluded || viewItem == pydevice.hostFolder || viewItem == pydevice.hostFolderExcluded || viewItem == pydevice.deviceFileLinked || viewItem == pydevice.deviceFileHostMissing || viewItem == pydevice.deviceFileUnlinked || viewItem == pydevice.deviceFileExcludedLinked || viewItem == pydevice.deviceFileExcludedHostMissing || viewItem == pydevice.deviceFileExcludedUnlinked || viewItem == pydevice.deviceFolder || viewItem == pydevice.deviceFolderExcluded)",
          "group": "navigation@8"
        },
        {
          "command": "mekatrol.pydevice.deletesyncpath",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && (viewItem == pydevice.hostFile || viewItem == pydevice.hostFileExcluded || viewItem == pydevice.hostFolder || viewItem == pydevice.hostFolderExcluded || viewItem == pydevice.deviceFileLinked || viewItem == pydevice.deviceFileHostMissing || viewItem == pydevice.deviceFileUnlinked || viewItem == pydevice.deviceFileExcludedLinked || viewItem == pydevice.deviceFileExcludedHostMissing || viewItem == pydevice.deviceFileExcludedUnlinked || viewItem == pydevice.deviceFolder || viewItem == pydevice.deviceFolderExcluded)",
          "group": "navigation@9"
        },
        {
          "command": "mekatrol.pydevice.linkdevicehostfolder",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && mekatrol.pydevice.hasHostSyncChildFolders && (viewItem == pydevice.deviceIdNode || viewItem == pydevice.deviceIdNodeLinked)",
          "group": "navigation@10"
        },
        {
          "command": "mekatrol.pydevice.unlinkdevicehostfolder",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && viewItem == pydevice.deviceIdNodeLinked",
          "group": "navigation@11"
        },
        {
          "command": "mekatrol.pydevice.adddevicelibraryfolder",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && (viewItem == pydevice.deviceIdNode || viewItem == pydevice.deviceIdNodeLinked)",
          "group": "navigation@11.2"
        },
        {
          "command": "mekatrol.pydevice.removedevicelibraryfolder",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && (viewItem == pydevice.deviceLibraryNode || viewItem == pydevice.deviceLibraryNodeMissing || viewItem == pydevice.deviceIdNode || viewItem == pydevice.deviceIdNodeLinked)",
          "group": "navigation@11.3"
        },
        {
          "command": "mekatrol.pydevice.setdevicename",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && (viewItem == pydevice.deviceIdNode || viewItem == pydevice.deviceIdNodeLinked)",
          "group": "navigation@12"
        },
        {
          "command": "mekatrol.pydevice.closedeviceconnection",
          "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && (viewItem == pydevice.deviceIdNode || viewItem == pydevice.deviceIdNodeLinked)",
          "group": "navigation@13"
        }
      ]
    },
    "keybindings": [
      {
        "command": "mekatrol.pydevice.renamesyncpath",
        "key": "f2",
        "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && listFocus"
      },
      {
        "command": "mekatrol.pydevice.deletesyncpath",
        "key": "delete",
        "mac": "backspace",
        "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && listFocus"
      },
      {
        "command": "mekatrol.pydevice.comparedevicewithcomputer",
        "key": "ctrl+alt+d",
        "mac": "cmd+alt+d",
        "when": "view == mekatrol.pydevice.syncExplorer && mekatrol.pydevice.explorerReady && listFocus"
      }
    ],
    "configuration": {
      "title": "Mekatrol Pydevice",
      "properties": {
        "mekatrol.pydevice.autoReconnectLastDevice": {
          "type": "boolean",
          "default": false,
          "description": "Automatically reconnect to the last selected device on startup if it was still connected when VS Code exited."
        },
        "mekatrol.pydevice.verboseReplTransportLogs": {
          "type": "boolean",
          "default": false,
          "description": "Show low-level REPL TX/RX transport logs in the extension output channel (for troubleshooting)."
        },
        "mekatrol.pydevice.deviceFileOpenWaitForConnectionMs": {
          "type": "number",
          "default": 120000,
          "minimum": 0,
          "description": "How long to wait for board connection before opening/saving device files fails. Set to 0 to wait indefinitely."
        },
        "mekatrol.pydevice.mountHostInWorkspaceExplorer": {
          "type": "boolean",
          "default": false,
          "description": "Mount HOST sync folder as a workspace folder in the native Explorer. Disabled by default to avoid workspace-save prompts."
        },
        "mekatrol.pydevice.mountDeviceInWorkspaceExplorer": {
          "type": "boolean",
          "default": false,
          "description": "Mount DEVICE as a workspace folder in the native Explorer. Enable only if your tooling supports non-file workspace schemes."
        },
        "mekatrol.pydevice.replHistoryLimit": {
          "type": "number",
          "default": 100,
          "minimum": 0,
          "description": "Maximum number of REPL history commands retained per device. Oldest entries are removed when limit is exceeded. Set to 0 to disable history retention."
        },
        "mekatrol.pydevice.statusDisplayMode": {
          "type": "string",
          "default": "extensionView",
          "enum": [
            "statusBar",
            "extensionView"
          ],
          "markdownEnumDescriptions": [
            "Show Pydevice status controls in the VS Code status bar.",
            "Show Pydevice status controls in the Pydevice sidebar view."
          ],
          "description": "Where to display Pydevice status controls."
        }
      }
    },
    "debuggers": [
      {
        "type": "pydevice",
        "label": "Pydevice",
        "languages": [
          "python"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "type",
              "request",
              "name"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "File path or URI to run on the connected device.",
                "default": "${file}"
              },
              "timeoutMs": {
                "type": "number",
                "description": "Execution timeout in milliseconds.",
                "default": 60000
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "pydevice",
            "request": "launch",
            "name": "Pydevice: Run Current File",
            "program": "${file}",
            "timeoutMs": 60000
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.109.0",
