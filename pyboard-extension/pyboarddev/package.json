{
  "name": "mekatrol-pyboard-dev",
  "publisher": "Mekatrol",
  "displayName": "Mekatrol Pyboard Dev",
  "description": "A pyboard (Micropython) developer extension.",
  "icon": "images/logo.png",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mekatrol.pyboarddev.initconfig",
        "title": "Pyboard Dev: Create configuration file"
      },
      {
        "command": "mekatrol.pyboarddev.selectdevice",
        "title": "Pyboard Dev: Select serial port",
        "enablement": "!mekatrol.pyboarddev.boardConnected"
      },
      {
        "command": "mekatrol.pyboarddev.selectpythontype",
        "title": "Pyboard Dev: Select Python type"
      },
      {
        "command": "mekatrol.pyboarddev.autodetectdevices",
        "title": "Pyboard Dev: Auto detect serial devices",
        "enablement": "!mekatrol.pyboarddev.boardConnected"
      },
      {
        "command": "mekatrol.pyboarddev.connectboard",
        "title": "Pyboard Dev: Connect to board"
      },
      {
        "command": "mekatrol.pyboarddev.disconnectboard",
        "title": "Pyboard Dev: Disconnect from board"
      },
      {
        "command": "mekatrol.pyboarddev.toggleboardconnection",
        "title": "Pyboard Dev: Toggle board connection"
      },
      {
        "command": "mekatrol.pyboarddev.setautoreconnect",
        "title": "Pyboard Dev: Set auto reconnect"
      },
      {
        "command": "mekatrol.pyboarddev.refreshmirrorview",
        "title": "Pyboard Dev: Refresh mirror explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "mekatrol.pyboarddev.syncfromdevice",
        "title": "Pyboard Dev: Sync from device",
        "icon": "$(cloud-download)"
      },
      {
        "command": "mekatrol.pyboarddev.synctodevice",
        "title": "Pyboard Dev: Sync to device",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "mekatrol.pyboarddev.openlocalmirroritem",
        "title": "Pyboard Dev: Open local mirror item"
      },
      {
        "command": "mekatrol.pyboarddev.pullandopendeviceitem",
        "title": "Pyboard Dev: Pull and open device item"
      },
      {
        "command": "mekatrol.pyboarddev.openremotefile",
        "title": "Pyboard Dev: Open remote device file"
      },
      {
        "command": "mekatrol.pyboarddev.openrepl",
        "title": "Pyboard Dev: Open REPL console"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "mekatrol.pyboarddev.localMirrorExplorer",
          "name": "Pyboard Mirror (Host)"
        },
        {
          "id": "mekatrol.pyboarddev.deviceFilesystemExplorer",
          "name": "Pyboard Device (Remote)"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "mekatrol.pyboarddev.selectdevice",
          "when": "!mekatrol.pyboarddev.boardConnected"
        },
        {
          "command": "mekatrol.pyboarddev.autodetectdevices",
          "when": "!mekatrol.pyboarddev.boardConnected"
        },
        {
          "command": "mekatrol.pyboarddev.connectboard",
          "when": "!mekatrol.pyboarddev.boardConnected"
        },
        {
          "command": "mekatrol.pyboarddev.disconnectboard",
          "when": "mekatrol.pyboarddev.boardConnected"
        }
      ],
      "view/title": [
        {
          "command": "mekatrol.pyboarddev.refreshmirrorview",
          "when": "view == mekatrol.pyboarddev.localMirrorExplorer || view == mekatrol.pyboarddev.deviceFilesystemExplorer",
          "group": "navigation@1"
        },
        {
          "command": "mekatrol.pyboarddev.syncfromdevice",
          "when": "view == mekatrol.pyboarddev.localMirrorExplorer || view == mekatrol.pyboarddev.deviceFilesystemExplorer",
          "group": "navigation@2"
        },
        {
          "command": "mekatrol.pyboarddev.synctodevice",
          "when": "view == mekatrol.pyboarddev.localMirrorExplorer || view == mekatrol.pyboarddev.deviceFilesystemExplorer",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "mekatrol.pyboarddev.openremotefile",
          "when": "view == mekatrol.pyboarddev.deviceFilesystemExplorer && viewItem == pyboarddev.deviceNode",
          "group": "inline@1"
        }
      ]
    },
    "configuration": {
      "title": "Mekatrol Pyboard Dev",
      "properties": {
        "mekatrol.pyboarddev.autoReconnectLastDevice": {
          "type": "boolean",
          "default": false,
          "description": "Automatically reconnect to the last selected device on startup if it was still connected when VS Code exited."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "mocha": "^11.7.5",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "serialport": "^13.0.0"
  }
}
