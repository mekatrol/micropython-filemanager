{
  "name": "mekatrol-pyboard-dev",
  "publisher": "Mekatrol",
  "displayName": "Mekatrol Pyboard Dev",
  "description": "A pyboard (Micropython) developer extension.",
  "icon": "images/logo.png",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onFileSystem:pyboarddev-remote"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mekatrol.pyboarddev.initconfig",
        "title": "Pyboard Dev: Create configuration file"
      },
      {
        "command": "mekatrol.pyboarddev.selectdevice",
        "title": "Pyboard Dev: Select serial port",
        "enablement": "!mekatrol.pyboarddev.boardConnected"
      },
      {
        "command": "mekatrol.pyboarddev.autodetectdevices",
        "title": "Pyboard Dev: Auto detect serial devices",
        "enablement": "!mekatrol.pyboarddev.boardConnected"
      },
      {
        "command": "mekatrol.pyboarddev.connectboard",
        "title": "Pyboard Dev: Connect to board"
      },
      {
        "command": "mekatrol.pyboarddev.disconnectboard",
        "title": "Pyboard Dev: Disconnect from board"
      },
      {
        "command": "mekatrol.pyboarddev.toggleboardconnection",
        "title": "Pyboard Dev: Toggle board connection"
      },
      {
        "command": "mekatrol.pyboarddev.softreboot",
        "title": "Pyboard Dev: Soft reboot device",
        "icon": "$(debug-restart)"
      },
      {
        "command": "mekatrol.pyboarddev.setautoreconnect",
        "title": "Pyboard Dev: Set auto reconnect"
      },
      {
        "command": "mekatrol.pyboarddev.refreshmirrorview",
        "title": "Pyboard Dev: Refresh mirror explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "mekatrol.pyboarddev.syncfromdevice",
        "title": "Pyboard Dev: Sync from device",
        "icon": "$(cloud-download)"
      },
      {
        "command": "mekatrol.pyboarddev.synctodevice",
        "title": "Pyboard Dev: Sync to device",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "mekatrol.pyboarddev.syncnodefromdevice",
        "title": "Sync From Device",
        "icon": "$(cloud-download)"
      },
      {
        "command": "mekatrol.pyboarddev.syncnodetodevice",
        "title": "Sync To Device",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "mekatrol.pyboarddev.openlocalmirroritem",
        "title": "Open Local Mirror Item"
      },
      {
        "command": "mekatrol.pyboarddev.pullandopendeviceitem",
        "title": "Pull and Open Device Item"
      },
      {
        "command": "mekatrol.pyboarddev.openremotefile",
        "title": "Open Remote Device File"
      },
      {
        "command": "mekatrol.pyboarddev.compareremotewithlocal",
        "title": "Compare Device File With Host",
        "icon": "$(diff)"
      },
      {
        "command": "mekatrol.pyboarddev.openrepl",
        "title": "Pyboard Dev: Open REPL console"
      },
      {
        "command": "mekatrol.pyboarddev.createmirrorfile",
        "title": "Create File",
        "icon": "$(new-file)"
      },
      {
        "command": "mekatrol.pyboarddev.createmirrorfolder",
        "title": "Create Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "mekatrol.pyboarddev.renamemirrorpath",
        "title": "Rename"
      },
      {
        "command": "mekatrol.pyboarddev.deletemirrorpath",
        "title": "Delete"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mekatrol-pyboarddev-sidebar",
          "title": "Pyboard Dev",
          "icon": "images/pyboarddev-sidebar.svg"
        }
      ]
    },
    "views": {
      "mekatrol-pyboarddev-sidebar": [
        {
          "id": "mekatrol.pyboarddev.mirrorExplorer",
          "name": "Pyboard Explorer"
        },
        {
          "id": "mekatrol.pyboarddev.statusView",
          "name": "PYBOARD",
          "when": "mekatrol.pyboarddev.showExtensionStatusView"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "mekatrol.pyboarddev.selectdevice",
          "when": "!mekatrol.pyboarddev.boardConnected"
        },
        {
          "command": "mekatrol.pyboarddev.autodetectdevices",
          "when": "!mekatrol.pyboarddev.boardConnected"
        },
        {
          "command": "mekatrol.pyboarddev.connectboard",
          "when": "!mekatrol.pyboarddev.boardConnected"
        },
        {
          "command": "mekatrol.pyboarddev.disconnectboard",
          "when": "mekatrol.pyboarddev.boardConnected"
        },
        {
          "command": "mekatrol.pyboarddev.softreboot",
          "when": "mekatrol.pyboarddev.boardConnected"
        }
      ],
      "view/title": [
        {
          "command": "mekatrol.pyboarddev.refreshmirrorview",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer",
          "group": "navigation@1"
        },
        {
          "command": "mekatrol.pyboarddev.syncfromdevice",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer",
          "group": "navigation@2"
        },
        {
          "command": "mekatrol.pyboarddev.synctodevice",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "mekatrol.pyboarddev.openlocalmirroritem",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && viewItem == pyboarddev.hostFile",
          "group": "navigation@1"
        },
        {
          "command": "mekatrol.pyboarddev.openremotefile",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && viewItem == pyboarddev.deviceFile",
          "group": "navigation@2"
        },
        {
          "command": "mekatrol.pyboarddev.compareremotewithlocal",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && (viewItem == pyboarddev.hostFile || viewItem == pyboarddev.deviceFile)",
          "group": "navigation@3"
        },
        {
          "command": "mekatrol.pyboarddev.syncnodefromdevice",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && (viewItem == pyboarddev.hostRoot || viewItem == pyboarddev.deviceRoot || viewItem == pyboarddev.hostFile || viewItem == pyboarddev.hostFolder || viewItem == pyboarddev.deviceFile || viewItem == pyboarddev.deviceFolder)",
          "group": "navigation@4"
        },
        {
          "command": "mekatrol.pyboarddev.syncnodetodevice",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && (viewItem == pyboarddev.hostRoot || viewItem == pyboarddev.deviceRoot || viewItem == pyboarddev.hostFile || viewItem == pyboarddev.hostFolder || viewItem == pyboarddev.deviceFile || viewItem == pyboarddev.deviceFolder)",
          "group": "navigation@5"
        },
        {
          "command": "mekatrol.pyboarddev.createmirrorfile",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && (viewItem == pyboarddev.hostRoot || viewItem == pyboarddev.deviceRoot || viewItem == pyboarddev.hostFolder || viewItem == pyboarddev.deviceFolder)",
          "group": "navigation@6"
        },
        {
          "command": "mekatrol.pyboarddev.createmirrorfolder",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && (viewItem == pyboarddev.hostRoot || viewItem == pyboarddev.deviceRoot || viewItem == pyboarddev.hostFolder || viewItem == pyboarddev.deviceFolder)",
          "group": "navigation@7"
        },
        {
          "command": "mekatrol.pyboarddev.renamemirrorpath",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && (viewItem == pyboarddev.hostFile || viewItem == pyboarddev.hostFolder || viewItem == pyboarddev.deviceFile || viewItem == pyboarddev.deviceFolder)",
          "group": "navigation@8"
        },
        {
          "command": "mekatrol.pyboarddev.deletemirrorpath",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && (viewItem == pyboarddev.hostFile || viewItem == pyboarddev.hostFolder || viewItem == pyboarddev.deviceFile || viewItem == pyboarddev.deviceFolder)",
          "group": "navigation@9"
        }
      ]
    },
    "keybindings": [
      {
        "command": "mekatrol.pyboarddev.renamemirrorpath",
        "key": "f2",
        "when": "view == mekatrol.pyboarddev.mirrorExplorer && listFocus"
      },
      {
        "command": "mekatrol.pyboarddev.deletemirrorpath",
        "key": "delete",
        "mac": "backspace",
        "when": "view == mekatrol.pyboarddev.mirrorExplorer && listFocus"
      },
      {
        "command": "mekatrol.pyboarddev.compareremotewithlocal",
        "key": "ctrl+alt+d",
        "mac": "cmd+alt+d",
        "when": "view == mekatrol.pyboarddev.mirrorExplorer && listFocus"
      }
    ],
    "configuration": {
      "title": "Mekatrol Pyboard Dev",
      "properties": {
        "mekatrol.pyboarddev.autoReconnectLastDevice": {
          "type": "boolean",
          "default": false,
          "description": "Automatically reconnect to the last selected device on startup if it was still connected when VS Code exited."
        },
        "mekatrol.pyboarddev.verboseReplTransportLogs": {
          "type": "boolean",
          "default": false,
          "description": "Show low-level REPL TX/RX transport logs in the extension output channel (for troubleshooting)."
        },
        "mekatrol.pyboarddev.remoteFileOpenWaitForConnectionMs": {
          "type": "number",
          "default": 120000,
          "minimum": 0,
          "description": "How long to wait for board connection before opening/saving remote device files fails. Set to 0 to wait indefinitely."
        },
        "mekatrol.pyboarddev.mountHostInWorkspaceExplorer": {
          "type": "boolean",
          "default": false,
          "description": "Mount HOST mirror folder as a workspace folder in the native Explorer. Disabled by default to avoid workspace-save prompts."
        },
        "mekatrol.pyboarddev.mountDeviceInWorkspaceExplorer": {
          "type": "boolean",
          "default": false,
          "description": "Mount DEVICE as a workspace folder in the native Explorer. Enable only if your tooling supports non-file workspace schemes."
        },
        "mekatrol.pyboarddev.statusDisplayMode": {
          "type": "string",
          "default": "extensionView",
          "enum": [
            "statusBar",
            "extensionView"
          ],
          "markdownEnumDescriptions": [
            "Show Pyboard status controls in the VS Code status bar.",
            "Show Pyboard status controls in the Pyboard sidebar view."
          ],
          "description": "Where to display Pyboard status controls."
        }
      }
    },
    "debuggers": [
      {
        "type": "pyboarddev",
        "label": "Pyboard Dev",
        "languages": [
          "python"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "type",
              "request",
              "name"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "File path or URI to run on the connected device.",
                "default": "${file}"
              },
              "timeoutMs": {
                "type": "number",
                "description": "Execution timeout in milliseconds.",
                "default": 60000
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "pyboarddev",
            "request": "launch",
            "name": "Pyboard Dev: Run Current File",
            "program": "${file}",
            "timeoutMs": 60000
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.3",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "mocha": "^11.7.5",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "serialport": "^13.0.0"
  }
}
