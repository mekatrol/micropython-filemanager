{
  "name": "mekatrol-pyboard-dev",
  "publisher": "Mekatrol",
  "displayName": "Mekatrol Pyboard Dev",
  "description": "A pyboard (Micropython) developer extension.",
  "icon": "images/logo.png",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onFileSystem:pyboarddev-device"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mekatrol.pyboarddev.initconfig",
        "title": "Pyboard Dev: Reset config"
      },
      {
        "command": "mekatrol.pyboarddev.selectdevice",
        "title": "Pyboard Dev: Select serial port"
      },
      {
        "command": "mekatrol.pyboarddev.autodetectdevices",
        "title": "Pyboard Dev: Auto detect serial devices",
        "icon": "$(search)"
      },
      {
        "command": "mekatrol.pyboarddev.connectboard",
        "title": "Pyboard Dev: Connect to board",
        "icon": "$(plug)"
      },
      {
        "command": "mekatrol.pyboarddev.connectboardwithpicker",
        "title": "Pyboard Dev: Connect to board (choose port)",
        "icon": "$(plug)"
      },
      {
        "command": "mekatrol.pyboarddev.connectboardesp32recovery",
        "title": "Pyboard Dev: ESP32 Recovery Connect",
        "icon": "$(debug-restart)"
      },
      {
        "command": "mekatrol.pyboarddev.disconnectboard",
        "title": "Pyboard Dev: Disconnect from board"
      },
      {
        "command": "mekatrol.pyboarddev.toggleboardconnection",
        "title": "Pyboard Dev: Toggle board connection"
      },
      {
        "command": "mekatrol.pyboarddev.softreboot",
        "title": "Pyboard Dev: Soft reboot device",
        "icon": "$(debug-restart)"
      },
      {
        "command": "mekatrol.pyboarddev.setautoreconnect",
        "title": "Pyboard Dev: Set auto reconnect"
      },
      {
        "command": "mekatrol.pyboarddev.refreshmirrorview",
        "title": "Pyboard Dev: Refresh mirror explorer",
        "icon": "$(refresh)"
      },
      {
        "command": "mekatrol.pyboarddev.syncfromdevice",
        "title": "Pyboard Dev: Sync from device to computer",
        "icon": "$(cloud-download)"
      },
      {
        "command": "mekatrol.pyboarddev.synctodevice",
        "title": "Pyboard Dev: Sync from computer to device",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "mekatrol.pyboarddev.syncnodefromdevice",
        "title": "Sync from device to computer",
        "icon": "$(cloud-download)"
      },
      {
        "command": "mekatrol.pyboarddev.syncnodetodevice",
        "title": "Sync from computer to device",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "mekatrol.pyboarddev.opencomputermirroritem",
        "title": "Open Computer Mirror Item"
      },
      {
        "command": "mekatrol.pyboarddev.pullandopendeviceitem",
        "title": "Pull and Open Device Item"
      },
      {
        "command": "mekatrol.pyboarddev.opendevicefile",
        "title": "Open Device File"
      },
      {
        "command": "mekatrol.pyboarddev.comparedevicewithcomputer",
        "title": "Compare Device File With Computer",
        "enablement": "viewItem != pyboarddev.deviceFileUnlinked && viewItem != pyboarddev.deviceFileExcludedUnlinked && viewItem != pyboarddev.deviceFileHostMissing && viewItem != pyboarddev.deviceFileExcludedHostMissing",
        "icon": "$(diff)"
      },
      {
        "command": "mekatrol.pyboarddev.openrepl",
        "title": "Pyboard Dev: Open REPL console"
      },
      {
        "command": "mekatrol.pyboarddev.clearrepl",
        "title": "Pyboard Dev: Clear REPL console",
        "icon": {
          "light": "images/clear-all-light.svg",
          "dark": "images/clear-all-dark.svg"
        }
      },
      {
        "command": "mekatrol.pyboarddev.clearreplhistory",
        "title": "Pyboard Dev: Clear REPL command history",
        "icon": {
          "light": "images/clear-history-light.svg",
          "dark": "images/clear-history-dark.svg"
        }
      },
      {
        "command": "mekatrol.pyboarddev.createmirrorfile",
        "title": "Create File",
        "icon": "$(new-file)"
      },
      {
        "command": "mekatrol.pyboarddev.createmirrorfolder",
        "title": "Create Folder",
        "icon": "$(new-folder)"
      },
      {
        "command": "mekatrol.pyboarddev.renamemirrorpath",
        "title": "Rename"
      },
      {
        "command": "mekatrol.pyboarddev.deletemirrorpath",
        "title": "Delete"
      },
      {
        "command": "mekatrol.pyboarddev.linkdevicehostfolder",
        "title": "Pyboard Dev: Link device to computer folder"
      },
      {
        "command": "mekatrol.pyboarddev.unlinkdevicehostfolder",
        "title": "Pyboard Dev: Unlink device from computer folder"
      },
      {
        "command": "mekatrol.pyboarddev.adddevicelibraryfolder",
        "title": "Pyboard Dev: Add device library folder"
      },
      {
        "command": "mekatrol.pyboarddev.removedevicelibraryfolder",
        "title": "Pyboard Dev: Remove device library folder"
      },
      {
        "command": "mekatrol.pyboarddev.setdevicename",
        "title": "Pyboard Dev: Set device name"
      },
      {
        "command": "mekatrol.pyboarddev.excludedevicefilefromsync",
        "title": "Exclude From Sync"
      },
      {
        "command": "mekatrol.pyboarddev.removedevicefilefromsyncexclusion",
        "title": "Remove Sync Exclusion"
      },
      {
        "command": "mekatrol.pyboarddev.closedeviceconnection",
        "title": "Close Connection",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "mekatrol.pyboarddev.closealldeviceconnections",
        "title": "Close All Connections",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "mekatrol.pyboarddev.mirrorExplorer.focus",
        "title": "Focus on Pyboard Explorer View"
      },
      {
        "command": "mekatrol.pyboarddev.statusView.focus",
        "title": "Focus on Pyboard View"
      },
      {
        "command": "mekatrol.pyboarddev.replView.focus",
        "title": "Focus on Pyboard REPL View"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mekatrol-pyboarddev-sidebar",
          "title": "Pyboard Dev",
          "icon": "images/pyboarddev-sidebar.svg"
        }
      ],
      "panel": [
        {
          "id": "mekatrol-pyboarddev-panel",
          "title": "Pyboard REPL",
          "icon": "images/pyboarddev-sidebar.svg"
        }
      ]
    },
    "views": {
      "mekatrol-pyboarddev-sidebar": [
        {
          "id": "mekatrol.pyboarddev.mirrorExplorer",
          "name": "Pyboard Explorer"
        },
        {
          "id": "mekatrol.pyboarddev.statusView",
          "name": "PYBOARD",
          "when": "mekatrol.pyboarddev.showExtensionStatusView"
        }
      ],
      "mekatrol-pyboarddev-panel": [
        {
          "id": "mekatrol.pyboarddev.replView",
          "name": "REPL",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "mekatrol.pyboarddev.initconfig",
          "when": "true"
        },
        {
          "command": "mekatrol.pyboarddev.selectdevice",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.autodetectdevices",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.connectboard",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.connectboardwithpicker",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.connectboardesp32recovery",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.disconnectboard",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.toggleboardconnection",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.softreboot",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.setautoreconnect",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.refreshmirrorview",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.syncfromdevice",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.synctodevice",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.syncnodefromdevice",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.syncnodetodevice",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.opencomputermirroritem",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.pullandopendeviceitem",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.opendevicefile",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.comparedevicewithcomputer",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.openrepl",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.clearrepl",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.clearreplhistory",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.createmirrorfile",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.createmirrorfolder",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.renamemirrorpath",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.deletemirrorpath",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.linkdevicehostfolder",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.unlinkdevicehostfolder",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.setdevicename",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.adddevicelibraryfolder",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.removedevicelibraryfolder",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.excludedevicefilefromsync",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.removedevicefilefromsyncexclusion",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.closedeviceconnection",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.closealldeviceconnections",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.mirrorExplorer.focus",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.statusView.focus",
          "when": "false"
        },
        {
          "command": "mekatrol.pyboarddev.replView.focus",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "mekatrol.pyboarddev.refreshmirrorview",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer",
          "group": "navigation@1"
        },
        {
          "command": "mekatrol.pyboarddev.syncfromdevice",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer",
          "group": "navigation@2"
        },
        {
          "command": "mekatrol.pyboarddev.synctodevice",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer",
          "group": "navigation@3"
        },
        {
          "command": "mekatrol.pyboarddev.clearrepl",
          "when": "view == mekatrol.pyboarddev.replView",
          "group": "navigation@1"
        },
        {
          "command": "mekatrol.pyboarddev.clearreplhistory",
          "when": "view == mekatrol.pyboarddev.replView",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "mekatrol.pyboarddev.opencomputermirroritem",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && (viewItem == pyboarddev.hostFile || viewItem == pyboarddev.hostFileExcluded)",
          "group": "navigation@1"
        },
        {
          "command": "mekatrol.pyboarddev.connectboardwithpicker",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && viewItem == pyboarddev.deviceRoot",
          "group": "inline@1"
        },
        {
          "command": "mekatrol.pyboarddev.connectboardesp32recovery",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && viewItem == pyboarddev.deviceRoot",
          "group": "inline@1.5"
        },
        {
          "command": "mekatrol.pyboarddev.closealldeviceconnections",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && viewItem == pyboarddev.deviceRoot && mekatrol.pyboarddev.boardConnected",
          "group": "inline@2"
        },
        {
          "command": "mekatrol.pyboarddev.autodetectdevices",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && viewItem == pyboarddev.deviceRoot",
          "group": "inline@3"
        },
        {
          "command": "mekatrol.pyboarddev.opendevicefile",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && (viewItem == pyboarddev.deviceFileLinked || viewItem == pyboarddev.deviceFileHostMissing || viewItem == pyboarddev.deviceFileUnlinked || viewItem == pyboarddev.deviceFileExcludedLinked || viewItem == pyboarddev.deviceFileExcludedHostMissing || viewItem == pyboarddev.deviceFileExcludedUnlinked)",
          "group": "navigation@2"
        },
        {
          "command": "mekatrol.pyboarddev.comparedevicewithcomputer",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && (viewItem == pyboarddev.hostFile || viewItem == pyboarddev.hostFileExcluded || viewItem == pyboarddev.deviceFileLinked || viewItem == pyboarddev.deviceFileExcludedLinked || viewItem == pyboarddev.deviceFileHostMissing || viewItem == pyboarddev.deviceFileExcludedHostMissing)",
          "group": "navigation@3"
        },
        {
          "command": "mekatrol.pyboarddev.syncnodefromdevice",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && (viewItem == pyboarddev.deviceFileLinked || viewItem == pyboarddev.deviceFileHostMissing || viewItem == pyboarddev.deviceFileUnlinked || viewItem == pyboarddev.deviceFolder || viewItem == pyboarddev.deviceIdNode || viewItem == pyboarddev.deviceIdNodeLinked || viewItem == pyboarddev.deviceLibraryNode || viewItem == pyboarddev.deviceLibraryNodeMissing)",
          "group": "navigation@4"
        },
        {
          "command": "mekatrol.pyboarddev.syncnodetodevice",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && (viewItem == pyboarddev.deviceFileLinked || viewItem == pyboarddev.deviceFileHostMissing || viewItem == pyboarddev.deviceFileUnlinked || viewItem == pyboarddev.deviceFolder || viewItem == pyboarddev.deviceIdNode || viewItem == pyboarddev.deviceIdNodeLinked || viewItem == pyboarddev.deviceLibraryNode || viewItem == pyboarddev.deviceLibraryNodeMissing)",
          "group": "navigation@5"
        },
        {
          "command": "mekatrol.pyboarddev.excludedevicefilefromsync",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && (viewItem == pyboarddev.deviceFileLinked || viewItem == pyboarddev.deviceFileHostMissing || viewItem == pyboarddev.deviceFileUnlinked || viewItem == pyboarddev.deviceFolder)",
          "group": "navigation@5.1"
        },
        {
          "command": "mekatrol.pyboarddev.removedevicefilefromsyncexclusion",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && (viewItem == pyboarddev.deviceFileExcludedLinked || viewItem == pyboarddev.deviceFileExcludedHostMissing || viewItem == pyboarddev.deviceFileExcludedUnlinked || viewItem == pyboarddev.deviceFolderExcluded)",
          "group": "navigation@5.2"
        },
        {
          "command": "mekatrol.pyboarddev.createmirrorfile",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && (viewItem == pyboarddev.hostRoot || viewItem == pyboarddev.hostFolder || viewItem == pyboarddev.deviceFolder || viewItem == pyboarddev.deviceIdNode || viewItem == pyboarddev.deviceIdNodeLinked || viewItem == pyboarddev.hostDeviceMappingNode || viewItem == pyboarddev.deviceLibraryNode || viewItem == pyboarddev.deviceLibraryNodeMissing)",
          "group": "navigation@6"
        },
        {
          "command": "mekatrol.pyboarddev.createmirrorfolder",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && (viewItem == pyboarddev.hostRoot || viewItem == pyboarddev.hostFolder || viewItem == pyboarddev.deviceFolder || viewItem == pyboarddev.deviceIdNode || viewItem == pyboarddev.deviceIdNodeLinked || viewItem == pyboarddev.hostDeviceMappingNode || viewItem == pyboarddev.deviceLibraryNode || viewItem == pyboarddev.deviceLibraryNodeMissing)",
          "group": "navigation@7"
        },
        {
          "command": "mekatrol.pyboarddev.renamemirrorpath",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && (viewItem == pyboarddev.hostFile || viewItem == pyboarddev.hostFileExcluded || viewItem == pyboarddev.hostFolder || viewItem == pyboarddev.hostFolderExcluded || viewItem == pyboarddev.deviceFileLinked || viewItem == pyboarddev.deviceFileHostMissing || viewItem == pyboarddev.deviceFileUnlinked || viewItem == pyboarddev.deviceFileExcludedLinked || viewItem == pyboarddev.deviceFileExcludedHostMissing || viewItem == pyboarddev.deviceFileExcludedUnlinked || viewItem == pyboarddev.deviceFolder || viewItem == pyboarddev.deviceFolderExcluded)",
          "group": "navigation@8"
        },
        {
          "command": "mekatrol.pyboarddev.deletemirrorpath",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && (viewItem == pyboarddev.hostFile || viewItem == pyboarddev.hostFileExcluded || viewItem == pyboarddev.hostFolder || viewItem == pyboarddev.hostFolderExcluded || viewItem == pyboarddev.deviceFileLinked || viewItem == pyboarddev.deviceFileHostMissing || viewItem == pyboarddev.deviceFileUnlinked || viewItem == pyboarddev.deviceFileExcludedLinked || viewItem == pyboarddev.deviceFileExcludedHostMissing || viewItem == pyboarddev.deviceFileExcludedUnlinked || viewItem == pyboarddev.deviceFolder || viewItem == pyboarddev.deviceFolderExcluded)",
          "group": "navigation@9"
        },
        {
          "command": "mekatrol.pyboarddev.linkdevicehostfolder",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && mekatrol.pyboarddev.hasHostMirrorChildFolders && (viewItem == pyboarddev.deviceIdNode || viewItem == pyboarddev.deviceIdNodeLinked)",
          "group": "navigation@10"
        },
        {
          "command": "mekatrol.pyboarddev.unlinkdevicehostfolder",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && viewItem == pyboarddev.deviceIdNodeLinked",
          "group": "navigation@11"
        },
        {
          "command": "mekatrol.pyboarddev.adddevicelibraryfolder",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && (viewItem == pyboarddev.deviceIdNode || viewItem == pyboarddev.deviceIdNodeLinked)",
          "group": "navigation@11.2"
        },
        {
          "command": "mekatrol.pyboarddev.removedevicelibraryfolder",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && (viewItem == pyboarddev.deviceLibraryNode || viewItem == pyboarddev.deviceLibraryNodeMissing || viewItem == pyboarddev.deviceIdNode || viewItem == pyboarddev.deviceIdNodeLinked)",
          "group": "navigation@11.3"
        },
        {
          "command": "mekatrol.pyboarddev.setdevicename",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && (viewItem == pyboarddev.deviceIdNode || viewItem == pyboarddev.deviceIdNodeLinked)",
          "group": "navigation@12"
        },
        {
          "command": "mekatrol.pyboarddev.closedeviceconnection",
          "when": "view == mekatrol.pyboarddev.mirrorExplorer && (viewItem == pyboarddev.deviceIdNode || viewItem == pyboarddev.deviceIdNodeLinked)",
          "group": "navigation@13"
        }
      ]
    },
    "keybindings": [
      {
        "command": "mekatrol.pyboarddev.renamemirrorpath",
        "key": "f2",
        "when": "view == mekatrol.pyboarddev.mirrorExplorer && listFocus"
      },
      {
        "command": "mekatrol.pyboarddev.deletemirrorpath",
        "key": "delete",
        "mac": "backspace",
        "when": "view == mekatrol.pyboarddev.mirrorExplorer && listFocus"
      },
      {
        "command": "mekatrol.pyboarddev.comparedevicewithcomputer",
        "key": "ctrl+alt+d",
        "mac": "cmd+alt+d",
        "when": "view == mekatrol.pyboarddev.mirrorExplorer && listFocus"
      }
    ],
    "configuration": {
      "title": "Mekatrol Pyboard Dev",
      "properties": {
        "mekatrol.pyboarddev.autoReconnectLastDevice": {
          "type": "boolean",
          "default": false,
          "description": "Automatically reconnect to the last selected device on startup if it was still connected when VS Code exited."
        },
        "mekatrol.pyboarddev.verboseReplTransportLogs": {
          "type": "boolean",
          "default": false,
          "description": "Show low-level REPL TX/RX transport logs in the extension output channel (for troubleshooting)."
        },
        "mekatrol.pyboarddev.deviceFileOpenWaitForConnectionMs": {
          "type": "number",
          "default": 120000,
          "minimum": 0,
          "description": "How long to wait for board connection before opening/saving device files fails. Set to 0 to wait indefinitely."
        },
        "mekatrol.pyboarddev.mountHostInWorkspaceExplorer": {
          "type": "boolean",
          "default": false,
          "description": "Mount HOST mirror folder as a workspace folder in the native Explorer. Disabled by default to avoid workspace-save prompts."
        },
        "mekatrol.pyboarddev.mountDeviceInWorkspaceExplorer": {
          "type": "boolean",
          "default": false,
          "description": "Mount DEVICE as a workspace folder in the native Explorer. Enable only if your tooling supports non-file workspace schemes."
        },
        "mekatrol.pyboarddev.replHistoryLimit": {
          "type": "number",
          "default": 100,
          "minimum": 0,
          "description": "Maximum number of REPL history commands retained per device. Oldest entries are removed when limit is exceeded. Set to 0 to disable history retention."
        },
        "mekatrol.pyboarddev.statusDisplayMode": {
          "type": "string",
          "default": "extensionView",
          "enum": [
            "statusBar",
            "extensionView"
          ],
          "markdownEnumDescriptions": [
            "Show Pyboard status controls in the VS Code status bar.",
            "Show Pyboard status controls in the Pyboard sidebar view."
          ],
          "description": "Where to display Pyboard status controls."
        }
      }
    },
    "debuggers": [
      {
        "type": "pyboarddev",
        "label": "Pyboard Dev",
        "languages": [
          "python"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "type",
              "request",
              "name"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "File path or URI to run on the connected device.",
                "default": "${file}"
              },
              "timeoutMs": {
                "type": "number",
                "description": "Execution timeout in milliseconds.",
                "default": 60000
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "pyboarddev",
            "request": "launch",
            "name": "Pyboard Dev: Run Current File",
            "program": "${file}",
            "timeoutMs": 60000
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
