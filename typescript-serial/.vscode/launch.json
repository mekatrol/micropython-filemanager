{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug main.ts",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npx",
            "runtimeArgs": [
                "ts-node",
                "--esm",
                "${workspaceFolder}/src/main.ts"
            ],
            "cwd": "${workspaceFolder}",
            "autoAttachChildProcesses": true,
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "env": {
                "TS_NODE_TRANSPILE_ONLY": "true",
                "NODE_OPTIONS": "--loader ts-node/esm"
            }
        }
    ]
}